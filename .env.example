# Razorpay API Keys
# Get from: https://dashboard.razorpay.com/app/keys
# Test keys start with rzp_test_, live keys start with rzp_live_
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_test_secret_here

# Public key for client-side JS SDK (one-time payments only)
# Must match RAZORPAY_KEY_ID — but exposed to browser
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx

# Webhook secret — DIFFERENT from API secret
# Set in: Dashboard → Settings → Webhooks → Secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# Plan IDs — DIFFERENT between test and live mode
# Create in: Dashboard → Subscriptions → Plans, or via API
RAZORPAY_PLAN_ID_MONTHLY=plan_xxxxxxxxxxxxx
RAZORPAY_PLAN_ID_YEARLY=plan_xxxxxxxxxxxxx

# Optional: Additional plans
# RAZORPAY_PLAN_ID_PRO_MONTHLY=plan_xxxxxxxxxxxxx
# RAZORPAY_PLAN_ID_ENTERPRISE_MONTHLY=plan_xxxxxxxxxxxxx

# ──────────────────────────────────────────────
# IMPORTANT NOTES:
# ──────────────────────────────────────────────
# 1. NEVER commit .env files — ensure .env* is in .gitignore
# 2. RAZORPAY_KEY_SECRET ≠ RAZORPAY_WEBHOOK_SECRET (they are different!)
# 3. Test plan IDs (plan_test_xxx) don't work in live mode and vice versa
# 4. NEXT_PUBLIC_ prefix exposes the value to the browser — only use for KEY_ID
# 5. Check Dashboard → Settings → Payments → Auto-capture is ON (critical!)
